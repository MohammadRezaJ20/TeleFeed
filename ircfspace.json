    {
      "id": 0,
      "message": "Ш§ЫҢЩҶ ЩҮЩҒШӘ Ъ©Ш§ШЁЩ„ Ш§ЫҢЩҶШӘШұЩҶШӘ Ш¬ЩҮШ§ЩҶЫҢ ШҜШұ Ш®Щ„ЫҢШ¬ ЩҒШ§ШұШі ШұЩҲ Ш§ЪҜЩҮ ЩӮШ·Ш№ Ъ©ЩҶЫҢШҜ Ш®ЫҢЩ„ЫҢ Ш®ЩҲШЁЩҮШҢ Ш§ЩҲЩҶШ§ ЩҮЩ… Щ…Ш«Щ„ Щ…Ш§ Ш§ЫҢЩҶШӘШұЩҶШӘ ЩҶШҜШ§ШҙШӘЩҮ ШЁШ§ШҙЩҶШҢ ШЁЩ„Ъ©ЩҮ ШҜЪ©Ш§ЩҶвҖҢЩҮШ§ЫҢ ШӯЩӮЩҲЩӮ ШӯШҙШұЫҢ ШөШҜШ§ШҙЩҲЩҶ ШЁШұШ§ЫҢ Ш§ЩҲЩҶШ§ ШҜШұШЁЫҢШ§ШҜ ЩҲ ЫҢЩҮ ЩҶЪҜШ§ЩҮЫҢ ЩҮЩ… Ш§ЫҢЩҶЩҲШұ ШЁЩҶШҜШ§ШІЩҶ ЩҲ ШҜЩ„ Щ…Ш§ ЩҮЩ… Ш®ЩҶЪ© ШЁШҙЩҮ!\u003cbr/\u003eЩӮШ·Ш№ Ъ©ЩҶЫҢШҜ.\u003cbr/\u003e\u003cbr/\u003e\u003ci class=\"emoji\" style=\"background-image:url(\u0026#39;//telegram.org/img/emoji/40/C2A9.png\u0026#39;)\"\u003e\u003cb\u003eВ©\u003c/b\u003e\u003c/i\u003e ehsan_369\u003cbr/\u003e\u003cbr/\u003e\u003ci class=\"emoji\" style=\"background-image:url(\u0026#39;//telegram.org/img/emoji/40/F09F9497.png\u0026#39;)\"\u003e\u003cb\u003eрҹ”—\u003c/b\u003e\u003c/i\u003e \u003ca href=\"https://ircf.space/\" target=\"_blank\" rel=\"noopener\" onclick=\"return confirm(\u0026#39;Open this link?\\n\\n\u0026#39;+this.href);\"\u003eбҙЎбҙҮКҷкңұЙӘбҙӣбҙҮ\u003c/a\u003e вҖў \u003ca href=\"https://t.me/persianvpnhub\" target=\"_blank\" rel=\"noopener\" onclick=\"return confirm(\u0026#39;Open this link?\\n\\n\u0026#39;+this.href);\"\u003eбҙ бҙҳЙҙКңбҙңКҷ\u003c/a\u003e вҖў \u003ca href=\"https://t.me/PersianGithubMirror\" target=\"_blank\" rel=\"noopener\" onclick=\"return confirm(\u0026#39;Open this link?\\n\\n\u0026#39;+this.href);\"\u003eЙўЙӘбҙӣКңбҙңКҷбҙҚЙӘКҖКҖбҙҸКҖ\u003c/a\u003e\u003cbr/\u003e\u003ca href=\"https://t.me/ircfspace\" target=\"_blank\"\u003e@ircfspace\u003c/a\u003e",
